# Modify our PATH
PATH=$HOME/bin:$HOME/.local/bin:$PATH

if [ -d "/opt/homebrew/bin" ]; then
  PATH=/opt/homebrew/bin:$PATH
fi


# SOURCE this file at the end of the default .bashrc file for the system
#
# INSTALL the following: lsd duf dust bat(or batcat) btop neovim yazi

# some more ls aliases
alias ls='lsd'
alias lsa='lsd -la'
alias ll='lsd -l'
alias lls='lsd -lS'
alias llt='lsd -lt'

alias top='btop'
alias du='dust -d 1'
alias df='duf'
alias mc='yazi' # map midnight commander mc to yazi

if ! command -v batcat &> /dev/null
then
	alias cat='bat'
else
	alias cat='batcat'
fi


# pacman / yay utils
alias yaytop="yay -Qe"
alias yayaur="yay -Qm"


# PROMPT
# INSTALL Starship for prompt: 
# curl -sS https://starship.rs/install.sh | sh
eval "$(starship init bash)"

